# OpenRouter API key (optional — users can set their own in the UI)
# NEXT_PUBLIC_OPENROUTER_KEY=

# Buy Me a Coffee username (optional — leave empty to hide all support UI)
# Set this to your BMC username to show the support button + floating widget
# NEXT_PUBLIC_BMC_USERNAME=your-username

# YouTube Data API v3 key (optional — users can set their own in the UI or defaults will be used)
# NEXT_PUBLIC_YOUTUBE_DATA_API_KEY=
