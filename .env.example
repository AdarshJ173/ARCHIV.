# === YouTube & Support ===
# Buy Me a Coffee username (optional — leave empty to hide all support UI)
NEXT_PUBLIC_BMC_USERNAME=

# YouTube Data API v3 key (optional — users can set their own in the UI)
NEXT_PUBLIC_YOUTUBE_DATA_API_KEY=

# === LLM Providers ===
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=

# === Backend Configuration ===
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=10

# === Feature Flags ===
ENABLE_HYDE=true
ENABLE_MULTI_QUERY=false
ENABLE_MMR=true
ENABLE_COMPRESSION=true

# === Advanced ===
DEVICE=auto
FAISS_INDEX_PATH=./data/faiss_index
BM25_INDEX_PATH=./data/bm25_index
